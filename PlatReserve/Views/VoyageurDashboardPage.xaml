<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlatReserve.Views.VoyageurDashboardPage"
             xmlns:model="clr-namespace:PlatReserve.Models"
             xmlns:conv="clr-namespace:PlatReserve.Converters"
             Shell.NavBarIsVisible="False"
             xmlns:vm="clr-namespace:PlatReserve.ViewModels"
             Title="Réserver un billet"
             x:DataType="vm:VoyageurViewModel">

    <!-- 1. C'est ici qu'on déclare les outils comme les couleurs -->
    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- On enregistre le convertisseur avec une clé unique -->
            <conv:HasPlacesConverter x:Key="VerifierPlaces" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- SECTION 1 : TES BILLETS -->
            <Label Text="Mes Billets Réservés" FontAttributes="Bold" FontSize="20" />

            <!-- On limite la hauteur pour ne pas que cette liste prenne toute la page -->
            <CollectionView ItemsSource="{Binding MesBillets}" EmptyView="Vous n'avez pas encore de billets.">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Billet">
                        <Frame Margin="0,5" Padding="10" BorderColor="Gray">

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer 
                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:VoyageurViewModel}}, Path=AllerAuxDetailsCommand}"
                        CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <HorizontalStackLayout Spacing="10">
                                <VerticalStackLayout WidthRequest="180">
                                    <Label Text="{Binding InfoReservation.TrajetConcerne.Depart, StringFormat='De: {0}'}" FontAttributes="Bold"/>
                                    <Label Text="{Binding InfoReservation.TrajetConcerne.Arrivee, StringFormat='Vers: {0}'}" />
                                    <!-- Un petit texte pour indiquer qu'on peut cliquer -->
                                    <Label Text="Toucher pour voir les détails" FontSize="9" TextColor="Blue" />
                                </VerticalStackLayout>

                                <!-- On garde ton bouton annuler séparé -->
                                <Button Text="Annuler" 
                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:VoyageurViewModel}}, Path=AnnulerBilletCommand}"
                            CommandParameter="{Binding .}"
                            BackgroundColor="Red" 
                            IsVisible="{Binding InfoReservation.AnnulationPossible}" 
                            VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Frame>

                     <!--   <HorizontalStackLayout Spacing="10">
                                <VerticalStackLayout WidthRequest="180">
                                    <Label Text="{Binding InfoReservation.TrajetConcerne.Depart, StringFormat='De: {0}'}" FontAttributes="Bold"/>
                                    <Label Text="{Binding InfoReservation.TrajetConcerne.Arrivee, StringFormat='Vers: {0}'}" />
                                    <Label Text="{Binding InfoReservation.MessageAnnulation}" 
                                           FontSize="10" 
                                           TextColor="Gray"/>
                                </VerticalStackLayout> -->

                                <!-- Bouton Annuler -->
                         <!--       <Button Text="Annuler" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:VoyageurViewModel}}, Path=AnnulerBilletCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Red" 
                                        IsVisible="{Binding InfoReservation.AnnulationPossible}" 
                                        VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Frame> -->
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

            <!-- SECTION 2 : LES TRAJETS DISPONIBLES -->
            <Label Text="Trajets Disponibles" FontAttributes="Bold" FontSize="20" />

            <CollectionView ItemsSource="{Binding TrajetsDisponibles}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Trajet">
                        <Border Margin="0,10" Padding="15" Stroke="#512BD4" StrokeShape="RoundRectangle 10">
                            <VerticalStackLayout Spacing="10">

                                <!-- Nom de l'Agence -->
                                <Label Text="{Binding BusAssigne.AgenceProprietaire.Nom}" 
                                       FontSize="22" FontAttributes="Bold" HorizontalOptions="Center"
                                       TextColor="#512BD4"/>

                                <BoxView HeightRequest="1" Color="LightGray" />

                                <!-- Villes -->
                                <Grid ColumnDefinitions="*, Auto, *">
                                    <Label Grid.Column="0" Text="{Binding Depart}" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                                    <Label Grid.Column="1" Text="➔" TextColor="Gray" VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="{Binding Arrivee}" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                                </Grid>

                                <!-- Horaires -->
                                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto">
                                    <Label Grid.Row="0" Grid.Column="0" Text="Départ :" FontSize="12" TextColor="Gray"/>
                                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding DateDepart, StringFormat='{0:dd/MM HH:mm}'}" FontAttributes="Bold"/>

                                    <Label Grid.Row="0" Grid.Column="1" Text="Arrivée :" FontSize="12" TextColor="Gray" HorizontalOptions="End"/>
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding DateArrivee, StringFormat='{0:dd/MM HH:mm}'}" FontAttributes="Bold" HorizontalOptions="End"/>
                                </Grid>

                                <Label Text="{Binding BusAssigne.NombreDePlaces, StringFormat='Places totales : {0}'}" FontSize="14"/>

                                <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                                    <Label Text="{Binding Prix, StringFormat='{0:F0} FCFA'}" TextColor="Green" FontSize="18" FontAttributes="Bold" />
                                    <Label Text="{Binding BusAssigne.PlacesRestantes, StringFormat='({0} libres)'}" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <Button Text="Réserver ce voyage" 
                                        CommandParameter="{Binding .}"
                                        Clicked="OnReserverClicked"
                                        CornerRadius="20" 
                                        
                                        IsEnabled="{Binding BusAssigne.PlacesRestantes, Converter={StaticResource VerifierPlaces}}">

                                    <!-- On définit l'apparence par défaut (Actif) -->
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Text" Value="Réserver ce voyage" />
                                            <Setter Property="BackgroundColor" Value="#512BD4" />
                                            <Setter Property="TextColor" Value="White" />

                                            <Style.Triggers>
                                                <!-- LA MAGIE DU TRIGGER : Si IsEnabled devient False -->
                                                <Trigger TargetType="Button" Property="IsEnabled" Value="False">
                                                    <Setter Property="BackgroundColor" Value="#CCCCCC" />
                                                    <Setter Property="TextColor" Value="#666666" />
                                                    <Setter Property="Text" Value="COMPLET" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>

                                </Button>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>