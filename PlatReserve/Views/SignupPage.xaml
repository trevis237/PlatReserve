<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PlatReserve.Views.SignupPage"
             xmlns:vm="clr-namespace:PlatReserve.ViewModels"
             x:DataType="vm:VoyageurViewModel"
            Title="Créer un compte Voyageur">

    <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">
        <Entry Text="{Binding Nom}" Placeholder="Nom" />
        <Entry Text="{Binding Phone}" Placeholder="Téléphone" />
        <Entry Text="{Binding Password}" Placeholder="Mot de passe" IsPassword="True" />
        <Button Text="S'inscrire" Command="{Binding SignupCommand}" />

        <Button Text="Déjà un compte ? Se connecter" Clicked="OnBackToLoginClicked" BackgroundColor="Transparent" TextColor="Gray" />
    </VerticalStackLayout>
</ContentPage>