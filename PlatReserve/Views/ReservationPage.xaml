<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:PlatReserve.Models"
             x:DataType="model:Trajet"
             xmlns:viewModel="clr-namespace:PlatReserve.ViewModels"
             x:Class="PlatReserve.Views.ReservationPage"
             Title="Reservation de Bus"
             >
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label x:Name="StatutLabel" Text="non connecte" TextColor="Red" />

            <BoxView HeightRequest="2" Color="Gray" Margin="0.10" />

            <!-- SECTION 2 : LISTE DES TRAJETS -->
            <Label Text="2. trajet disponibles" FontSize="20" FontAttributes="Bold" />

            <CollectionView ItemsSource="{Binding TousLesTrajets}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,5,0,5" Padding="10" Stroke="LightGray">
                            <VerticalStackLayout>
                                <Label Text="{Binding Depart, StringFormat='De : {0}'}" FontAttributes="Bold" />
                                <Label Text="{Binding Arrivee, StringFormat='À : {0}'}" FontAttributes="Bold" />
                                <Label Text="{Binding BusAssigne.PlacesRestantes, StringFormat='Places restantes : {0}'}" TextColor="Green" />

                                <Button Text="Resrver ce trajet"
                                 Clicked="OnReserverClicked"
                                 CommandParameter="{Binding .}"
                                 Margin="0,10,0,0" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>